---
import SectionHeader from './SectionHeader.astro';
const links = [
  { label: 'Email', value: 'azmainmahtab@protonmail.com', href: 'mailto:azmainmahtab@protonmail.com', icon: 'mail' },
  { label: 'GitHub', value: 'github.com/AzmainMahtab', href: 'https://github.com/AzmainMahtab', icon: 'github' },
  { label: 'LinkedIn', value: 'linkedin.com/in/azmain-mahtab-seam', href: 'https://linkedin.com/in/azmain-mahtab-seam', icon: 'linkedin' },
];
---
<section id="contact" class="py-32 container">
  <SectionHeader index="05" title="Let's build something." subtitle="Got a backend that needs taming or a system that needs scaling? My inbox is open." />
  <div class="grid md:grid-cols-3 gap-5">
    {links.map((l) => (
      <a href={l.href} target={l.href.startsWith('http') ? '_blank' : undefined} rel="noreferrer" class="surface-card p-7 flex flex-col gap-3 group">
        <div class="flex items-center justify-between">
          <span class="text-primary-container">
            {l.icon === 'mail' && <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>}
            {l.icon === 'github' && <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3"/></svg>}
            {l.icon === 'linkedin' && <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M20.4 20.4h-3.6v-5.6c0-1.3 0-3-1.8-3s-2.1 1.4-2.1 2.9v5.7H9.4V9h3.4v1.6h.1c.5-.9 1.7-1.8 3.4-1.8 3.6 0 4.3 2.4 4.3 5.5v6.1zM5.3 7.4a2.1 2.1 0 1 1 0-4.2 2.1 2.1 0 0 1 0 4.2zM7.1 20.4H3.5V9h3.6v11.4zM22.2 0H1.8C.8 0 0 .8 0 1.7v20.5c0 1 .8 1.7 1.8 1.7h20.4c1 0 1.8-.8 1.8-1.7V1.7c0-1-.8-1.7-1.8-1.7z"/></svg>}
          </span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-muted-foreground group-hover:text-primary-container transition-transform group-hover:-translate-y-1 group-hover:translate-x-1"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
        </div>
        <p class="font-mono text-xs text-muted-foreground mt-2">{l.label}</p>
        <p class="font-display text-lg break-all group-hover:text-primary-container transition-colors">{l.value}</p>
      </a>
    ))}
  </div>
</section>

---
import SectionHeader from './SectionHeader.astro';
import { PROJECTS } from '../data/portfolio';
---
<section id="projects" class="py-32 container">
  <SectionHeader index="04" title="Selected work" subtitle="A few systems I've had the privilege of architecting, breaking and rebuilding." />
  <div class="grid md:grid-cols-2 gap-6">
    {PROJECTS.map((p, i) => (
      <article class="surface-card p-8 flex flex-col group relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-primary-container/5 rounded-full blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <p class="font-mono text-xs text-primary-container mb-3">project_0{i + 1}</p>
        <h3 class="font-display text-2xl font-semibold mb-3 group-hover:text-primary-container transition-colors">{p.title}</h3>
        <p class="text-muted-foreground leading-relaxed mb-5">{p.blurb}</p>
        <ul class="space-y-2 mb-6 text-sm text-muted-foreground/90">
          {p.bullets.map((b) => <li class="flex gap-2"><span class="text-primary-container font-mono">›</span><span>{b}</span></li>)}
        </ul>
        <div class="mt-auto flex flex-wrap gap-1.5">
          {p.stack.map((s) => <span class="text-[11px] font-mono px-2 py-1 rounded-md bg-surface-high text-muted-foreground">{s}</span>)}
        </div>
      </article>
    ))}
  </div>
</section>
